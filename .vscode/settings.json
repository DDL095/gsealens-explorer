{
  "files.encoding": "utf8",
  "files.eol": "\r\n",
  "[r]": { "files.eol": "\n" },
  "[python]": { "files.eol": "\n" },
  "[shellscript]": { "files.eol": "\n" },
  "search.exclude": {
    "**/.local_overrides": true,
    "**/out": true,
    "**/*.rds": true,
    "**/.audit": true
  },
  "markdown.preview.typographer": true,
  "r.rterm.windows": "R.exe",
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}
